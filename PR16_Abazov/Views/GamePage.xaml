<Page x:Class="PR16_Abazov.Views.GamePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="GamePage">
    <Grid Background="#1E1E1E">
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="50"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="180"/>
        </Grid.RowDefinitions>

        <TextBlock Text="ABAZOV ADVENTURE" Foreground="Goldenrod" FontSize="28" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold"/>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock x:Name="TxtFloor" Text="ЭТАЖ: 1" Foreground="White" FontSize="18" Margin="20,0"/>
            <ProgressBar x:Name="HpBar" Width="300" Height="25" Minimum="0" Maximum="100" Value="100" Foreground="Red" Background="#333"/>
            <TextBlock x:Name="TxtHp" Text="100 / 100" Foreground="White" FontSize="18" Margin="10,0"/>
        </StackPanel>

        <Border Grid.Row="2" BorderBrush="Goldenrod" BorderThickness="2" Margin="10" CornerRadius="5">
            <Grid>
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock x:Name="TxtRoomTitle" Text="Впереди враг!" Foreground="White" FontSize="24" HorizontalAlignment="Center" Margin="10"/>
                    <Image x:Name="ImgEntity" Source="/Resources/Images/placeholder.png" Width="200" Height="200" Stretch="Uniform"/>
                    <StackPanel x:Name="PanelActions" Orientation="Horizontal" HorizontalAlignment="Center" Margin="20">
                        <Button x:Name="BtnAttack" Content="АТАКА" Width="120" Height="40" Margin="10" Background="DarkRed" Foreground="White" Click="BtnAttack_Click"/>
                        <Button x:Name="BtnGuard" Content="ЗАЩИТА" Width="120" Height="40" Margin="10" Background="DarkBlue" Foreground="White" Click="BtnGuard_Click"/>
                    </StackPanel>
                    <ListBox x:Name="EnemyListBox" Height="150" Background="#252526" Foreground="White" 
                         BorderBrush="#3F3F46" SelectionChanged="EnemyListBox_SelectionChanged">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding TypeName}" FontWeight="Bold" Width="100"/>
                                    <TextBlock Text="HP: " Foreground="Red"/>
                                    <TextBlock Text="{Binding BaseHP}" Foreground="Red"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <StackPanel x:Name="PanelChest" Orientation="Horizontal" HorizontalAlignment="Center" Visibility="Collapsed">
                        <Button Content="ВЗЯТЬ" Width="100" Height="40" Click="BtnTake_Click" Margin="5"/>
                        <Button Content="ВЫБРОСИТЬ" Width="100" Height="40" Click="BtnSkip_Click" Margin="5"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="3" Margin="10,0,10,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="350"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <GroupBox Header="ЭКИПИРОВКА" Foreground="White" Margin="5">
                <StackPanel>
                    <TextBlock x:Name="TxtWeapon" Text="Оружие: Нет" Foreground="LightGray" Margin="5"/>
                    <TextBlock x:Name="TxtArmor" Text="Доспехи: Нет" Foreground="LightGray" Margin="5"/>
                </StackPanel>
            </GroupBox>

            <GroupBox Header="ЖУРНАЛ СОБЫТИЙ" Foreground="White" Grid.Column="1" Margin="5">
                <ListBox x:Name="LstLog" Background="Black" Foreground="LightGreen" BorderThickness="0" FontSize="12"/>
            </GroupBox>
        </Grid>
    </Grid>
</Page>