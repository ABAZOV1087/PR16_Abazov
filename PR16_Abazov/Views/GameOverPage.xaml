<Page x:Class="PR16_Abazov.Views.GameOverPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="GameOverPage">
    <Grid Background="#440000">
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock Text="ВЫ ПОГИБЛИ" FontSize="72" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center"/>
            <TextBlock x:Name="TxtFinalFloor" Text="Вы дошли до 1 этажа" FontSize="24" Foreground="LightGray" HorizontalAlignment="Center" Margin="20"/>
            <Button Content="ВЕРНУТЬСЯ В МЕНЮ" Width="250" Height="60" FontSize="18" Click="BtnRestart_Click"/>
        </StackPanel>
    </Grid>
</Page>